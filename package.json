{
  "name": "eip",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "gen:contracts": "pnpm --filter @eip/contracts gen",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format:check": "prettier --check \"web/**/*.{ts,tsx,mjs,json}\"",
    "format:write": "prettier --write \"web/**/*.{ts,tsx,mjs,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
