# EIP dev environment — copy to `.env` and fill in secrets. `.env` is gitignored.
# Loaded automatically by `scripts/dev.sh` (`pnpm dev`). For a single service run
# manually:  set -a; . ./.env; set +a
#
# NEVER commit real secrets. This file (.env.example) holds placeholders only.

# === LLM provider (OpenRouter — one key, many models; ADR-0009) ===========
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# Any slug from https://openrouter.ai/models (e.g. openai/gpt-5, google/gemini-2.5-pro)
OPENROUTER_MODEL=anthropic/claude-opus-4.8
# Cap output tokens per call (default 1024). Raise it as your credit allows;
# OpenRouter charges/credit-checks against this ceiling.
# OPENROUTER_MAX_TOKENS=1024
# Optional attribution headers shown on OpenRouter:
# OPENROUTER_SITE_URL=https://example.org
# OPENROUTER_APP_NAME=ProjectGolem (dev)
# Fallback provider — used only when OPENROUTER_API_KEY is unset:
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# === Gateway auth (leave UNSET for open dev mode so the portal works keyless) ==
# Keys are "key:scope1 scope2", entries ;-separated. Quote (has spaces):
# EIP_API_KEYS="dev-key:write read"

# === Data stores — uncomment ONLY after starting them, or services that read
# them at startup (Postgres) will fail to boot:
#   docker compose -f infra/docker-compose.yml up -d
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=evidence
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=devpassword
# POSTGRES_DSN=postgresql+psycopg://eip:devpassword@localhost:5432/eip

# === Service URLs (defaults match scripts/dev.sh; override only if needed) =====
# TRUST_ENGINE_URL=http://localhost:8000
# CLAIM_ENGINE_URL=http://localhost:8001
# EVIDENCE_ENGINE_URL=http://localhost:8002
# GATEWAY_URL=http://localhost:4000
